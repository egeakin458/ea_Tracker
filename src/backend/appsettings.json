{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "ServerVersion": "8.0.42"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Investigation": {
    "Invoice": {
      "MaxTaxRatio": 0.5,
      "CheckNegativeAmounts": true,
      "CheckFutureDates": true,
      "MaxFutureDays": 0
    },
    "Waybill": {
      "ExpiringSoonHours": 24,
      "LegacyCutoffDays": 7,
      "CheckOverdueDeliveries": true,
      "CheckExpiringSoon": true,
      "CheckLegacyWaybills": true
    }
  }
}
